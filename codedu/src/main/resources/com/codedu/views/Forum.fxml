<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.codedu.controllers.ForumController"
      alignment="TOP_CENTER" spacing="20" maxWidth="900">

    <padding>
        <Insets top="10" right="0" bottom="10" left="0"/>
    </padding>

    <Label fx:id="titleLabel" text="Forum"/>
    <Label fx:id="subtitleLabel"
           text="Ask questions, share tips, and read what other learners are working on."
           wrapText="true"/>

    <VBox fx:id="threadList" spacing="16" fillWidth="true"/>

</VBox>

