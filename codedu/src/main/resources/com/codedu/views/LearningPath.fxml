<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.codedu.controllers.LearningPathController">

    <top>
        <VBox spacing="4">
            <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Learning path"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="chapterCountLabel" text="0 Chapters"/>
            </HBox>

            <Label text="Master programming step-by-step. Complete chapters to unlock new challenges and earn XP."/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox fx:id="pathContainer" alignment="TOP_CENTER" spacing="0">
                <padding><Insets top="20" right="40" bottom="40" left="40"/></padding>
            </VBox>
        </ScrollPane>
    </center>

    <right>
        <VBox fx:id="detailPanel" spacing="12"
              prefWidth="280" visible="false" managed="false">
            <padding><Insets top="24" right="20" bottom="24" left="20"/></padding>

            <ImageView fx:id="detailIconImage" fitWidth="72" fitHeight="72" preserveRatio="true"/>
            <Label fx:id="detailTitle"/>
            <Label fx:id="detailDifficulty"/>
            <Label fx:id="detailDescription" wrapText="true"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="detailLessons"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="detailXP"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <StackPane alignment="CENTER">
                <Label fx:id="detailAction" text="Start chapter"/>
            </StackPane>
        </VBox>
    </right>

</BorderPane>